    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@chalbert/enzyme-adapter-react-18": "^0.7.2",
    "@eslint/js": "^9.39.4",
    "@peculiar/webcrypto": "^1.7.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "auto": "^11.3.6",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.2.1",
    "css-loader": "^6.11.0",
    "dotenv-webpack": "^6.0.4",
    "enzyme": "^3.11.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
